<theme>
	
    <include>./colors.xml</include>
    <include>./fonts.xml</include>
    <include>./_inc/system/metadata/_default.xml</include>
    <include>./_inc/system/metadata/${system.theme}.xml</include>
    
    <view name="system, gamelist">
        <carousel name="system-carousel,games-carousel">
            <pos>0 0.010</pos>
            <size>1 0.5500</size>
            <selectedItemOffset>0 0.0150</selectedItemOffset>
            <horizontalOffset>-0.3510</horizontalOffset>
            <verticalOffset>-0.2030</verticalOffset>
            <itemScale>1.6</itemScale>
            <maxItemCount>19</maxItemCount>
            <selectedItemMargins>0.015 0.015</selectedItemMargins>
            <itemSize>0.045 0.115</itemSize>
        </carousel>
        <systemstatus name="system-status">
            <pos>0.850 0.050</pos>
            <textRelativeScale>0.950</textRelativeScale>
            <entrySpacing>0.010</entrySpacing>
        </systemstatus>
        <clock name="clock">
            <pos>0.930 0.050</pos>
            <fontSize>${clockFontSize}</fontSize>
        </clock>
        <text name="system-tab,games-tab">
            <fontSize>${clockFontSize}</fontSize>
        </text>
        <text name="system-tab">
            <pos>0.090 0.050</pos>
        </text>
        <text name="games-tab">
            <pos>0.180 0.050</pos>
        </text>
        <text name="system-games-name">
            <pos>0.220 0.233</pos>
            <size>0.745 0.0695</size>
            <fontSize>${carouselTitleFontSize}</fontSize>
        </text>
        <image name="gamesystem-logo">
            <pos>0.195 0.265</pos>
            <maxSize>0.05 0.05</maxSize>
        </image>
        <image name="metadata-background">
            <pos>0.076 0.820</pos>
            <size>0.230 0.0621</size>
        </image>
        <image name="media-screenshot">
        	<pos>0.830 0.730</pos>
        	<maxSize>0.250 0.3250</maxSize>
            </image>
            <video name="media-video">
            <pos>${playAudioOnly}</pos>
            <cropSize>0.210 0.320</cropSize>
        </video>
        <image name="avatar-icon">
            <pos>0.870 0.050</pos>
            <maxSize>0.050 0.050</maxSize>
        </image>
        <image name="avatar-icon-online">
            <pos>0.880 0.070</pos>
            <size>0.007 0.017</size>
        </image>
    </view>
    
    <view name="system">
        <image name="system-gamecount-icon">
            <pos>0.0920 0.820</pos>
            <size>0 0.030</size>
        </image>
        <text name="system-gamecount">
            <pos>0.1200 0.820</pos>
            <size>0.2398 0.0444</size>
            <fontSize>${metadataFontSize}</fontSize>
        </text>
        <image name="system-favorites-icon">
            <pos>0.2400 0.820</pos>
            <size>0 0.0278</size>
        </image>
        <text name="system-favorites">
            <pos>0.2600 0.820</pos>
            <size>0.0336 0.0444</size>
            <fontSize>${metadataFontSize}</fontSize>
        </text>
        <image name="system-metadata-divider">
            <pos>0.230 0.820</pos>
            <size>0.0016 0.0611</size>
        </image>
        <image name="system-lastplayed-icon">
            <pos>0.110 0.715</pos>
            <size>0 0.0310</size>
        </image>
        <text name="system-lastplayed">
            <pos>0.300 0.710</pos>
            <size>0.350 0.0695</size>
            <fontSize>${metadataFontSize}</fontSize>
        </text>
        <image name="system-marquee">
                <pos>0.190 0.600</pos>
                <maxSize>0.210 0.130</maxSize>
            </image>
    </view>
    
    <view name="gamelist">
        <image name="gamelist-metadata-players-icon">
            <pos>0.0870 0.820</pos>
            <size>0 0.0278</size>
        </image>
        <text name="gamelist-metadata-players">
            <pos>0.105 0.820</pos>
            <size>0.0380 0.0278</size>
            <fontSize>${metadataFontSize}</fontSize>
        </text>
        <image name="gamelist-metadata-playtime-icon">
            <pos>0.1530 0.820</pos>
            <size>0 0.0278</size>
        </image>
        <text name="gamelist-metadata-playtime">
            <pos>0.1730 0.820</pos>
            <size>0.070 0.0278</size>
            <fontSize>${metadataFontSize}</fontSize>
        </text>
        <image name="gamelist-metadata-playcount-icon">
            <pos>0.2480 0.820</pos>
            <size>0 0.0278</size>
        </image>
        <text name="gamelist-metadata-playcount">
            <pos>0.2700 0.820</pos>
            <size>0.0313 0.0278</size>
            <fontSize>${metadataFontSize}</fontSize>
        </text>
        <image name="gamelist-metadata-left-divider">
            <pos>0.1450 0.820</pos>
            <size>0.0016 0.0611</size>
        </image>
        <image name="gamelist-metadata-middle-divider">
            <pos>0.2400 0.820</pos>
            <size>0.0016 0.0611</size>
        </image>
        <badges name="gamelist-badges-right">
            <size>0.230 1</size>
            <itemMargin>0.006 0</itemMargin>
            <pos>0.310 0.790</pos>
        </badges>
        <badges name="gamelist-badges-left">
            <size>0.135 1</size>
            <itemMargin>0.008 0</itemMargin>
            <pos>0.04 0.790</pos>
        </badges>
        <text name="gamelist-genre-name">
            <pos>0.195 0.710</pos>
            <size>0.350 0.0695</size>
            <fontSize>${metadataFontSize}</fontSize>
        </text>
        <image name="game-marquee">
                <pos>0.200 0.575</pos>
                <maxSize>0.210 0.215</maxSize>
            </image>
    </view>
    
</theme>
