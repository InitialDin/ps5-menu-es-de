        </text>
        <image name="system-metadata-divider">
            <pos>0.2530 0.815</pos>
            <size>0.0016 0.0611</size>
        </image>
        <image name="system-marquee">
                <pos>0.215 0.600</pos>
                <maxSize>0.230 0.150</maxSize>
            </image>
    </view>
    
    <view name="gamelist">
        <image name="gamelist-carousel-selector">
            <pos>0.2516 0.3708</pos>
            <size>0.3172 0.5639</size>
