<theme>
	
    <include>./colors.xml</include>
    <include>./_inc/system/metadata/_default.xml</include>
    <include>./_inc/system/metadata/${system.theme}.xml</include>
    
    <view name="system, gamelist">
        <systemstatus name="system-status">
            <pos>0.800 0.050</pos>
            <textRelativeScale>0.950</textRelativeScale>
            <entrySpacing>0.010</entrySpacing>
        </systemstatus>
        <clock name="clock">
            <pos>0.910 0.050</pos>
            <fontSize>${clockFontSize}</fontSize>
        </clock>
        <text name="system-tab,games-tab">
            <fontSize>${clockFontSize}</fontSize>
        </text>
        <text name="system-tab">
            <pos>0.080 0.050</pos>
        </text>
        <text name="games-tab">
            <pos>0.180 0.050</pos>
        </text>
        <image name="metadata-background">
            <pos>0.076 0.815</pos>
