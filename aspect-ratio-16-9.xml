        <image name="game-marquee">
                <pos>0.215 0.600</pos>
                <maxSize>0.230 0.250</maxSize>
            </image>
        <image name="gamelist-media-screenshot">
        	<pos>0.830 0.730</pos>
        	<maxSize>0.250 0.3250</maxSize>
            </image>
            <video name="gamelist-media-video">
            <pos>${playAudioOnly}</pos>
            <cropSize>0.250 0.3250</cropSize>
        </video>
    </view>
    
</theme>
