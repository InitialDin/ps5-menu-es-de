<theme>
	
    <include>./colors.xml</include>
    <include>./fonts.xml</include>
    <include>./_inc/system/metadata/_default.xml</include>
    <include>./_inc/system/metadata/${system.theme}.xml</include>
    
    <view name="system, gamelist">
        <carousel name="system-carousel,games-carousel">
            <pos>0 0</pos>
            <size>1 0.5500</size>
            <selectedItemOffset>0 0.0200</selectedItemOffset>
            <horizontalOffset>-0.3510</horizontalOffset>
            <verticalOffset>-0.2030</verticalOffset>
            <itemScale>1.6</itemScale>
            <maxItemCount>14</maxItemCount>
            <selectedItemMargins>0.020 0.020</selectedItemMargins>
            <itemSize>0.065 0.120</itemSize>
        </carousel>
        <systemstatus name="system-status">
            <pos>0.800 0.050</pos>
            <textRelativeScale>0.950</textRelativeScale>
            <entrySpacing>0.010</entrySpacing>
        </systemstatus>
        <clock name="clock">
            <pos>0.910 0.050</pos>
            <fontSize>${clockFontSize}</fontSize>
        </clock>
        <text name="system-tab,games-tab">
            <fontSize>${clockFontSize}</fontSize>
        </text>
        <text name="system-tab">
            <pos>0.080 0.050</pos>
        </text>
        <text name="games-tab">
            <pos>0.180 0.050</pos>
        </text>
        <text name="system-games-name">
            <pos>0.240 0.231</pos>
            <size>0.745 0.0695</size>
            <fontSize>${carouselTitleFontSize}</fontSize>
        </text>
        <image name="gamesystem-logo">
            <pos>0.208 0.265</pos>
            <maxSize>0.05 0.05</maxSize>
        </image>
        <image name="metadata-background">
            <pos>0.076 0.815</pos>
            <size>0.285 0.0621</size>
        </image>
        <image name="avatar-icon">
            <pos>0.830 0.050</pos>
            <maxSize>0.050 0.050</maxSize>
        </image>
        <image name="avatar-icon-online">
            <pos>0.840 0.070</pos>
            <size>0.007 0.012</size>
        </image>
    </view>
    
    <view name="system">
        <image name="system-gamecount-icon">
            <pos>0.0920 0.815</pos>
            <size>0 0.030</size>
        </image>
        <text name="system-gamecount">
            <pos>0.1200 0.815</pos>
            <size>0.2398 0.0444</size>
            <fontSize>${metadataFontSize}</fontSize>
        </text>
        <image name="system-favorites-icon">
