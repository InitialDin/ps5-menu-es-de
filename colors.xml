<theme>
    	
    <colorScheme name="mediavideo,mediascreenshot,mediavideo-audio,mediavideo-audio-screenshot,nomedia,backgroundvideo,backgroundvideo-screenshot">
        <variables>
            <white>FFFFFF</white>
            <black>000000</black>
            <grey>7C7C7C</grey>
            <greyUnfocused>A3A3A3</greyUnfocused>
            <divider>83838388</divider>
            <online>3BE795</online>
        </variables>
    </colorScheme>
    
    <colorScheme name="mediavideo">
        <variables>
            <showMediaVideoSystem>true</showMediaVideoSystem>
            <showMediaVideoGamelist>true</showMediaVideoGamelist>
            <showLastPlayed>true</showLastPlayed>
            <showMediaScreenshot>false</showMediaScreenshot>
            <mediaVideoPos>0.830 0.725</mediaVideoPos>
            <showBackgroundVideo>false</showBackgroundVideo>
            <showBackgroundArt>true</showBackgroundArt>
        </variables>
    </colorScheme>
    
    <colorScheme name="mediascreenshot">
        <variables>
            <showMediaVideoSystem>false</showMediaVideoSystem>
            <showMediaVideoGamelist>false</showMediaVideoGamelist>
            <showLastPlayed>true</showLastPlayed>
            <showMediaScreenshot>true</showMediaScreenshot>
            <mediaVideoPos>0.830 0.700</mediaVideoPos>
            <showBackgroundVideo>false</showBackgroundVideo>
            <showBackgroundArt>true</showBackgroundArt>
        </variables>
    </colorScheme>
    
    <colorScheme name="mediavideo-audio">
        <variables>
            <showMediaVideoSystem>true</showMediaVideoSystem>
            <showMediaVideoGamelist>true</showMediaVideoGamelist>
            <showLastPlayed>true</showLastPlayed>
            <showMediaScreenshot>false</showMediaScreenshot>
            <mediaVideoPos>999 999</mediaVideoPos>
            <showBackgroundVideo>false</showBackgroundVideo>
            <showBackgroundArt>true</showBackgroundArt>
        </variables>
    </colorScheme>
    
    <colorScheme name="mediavideo-audio-screenshot">
        <variables>
            <showMediaVideoSystem>false</showMediaVideoSystem>
            <showMediaVideoGamelist>true</showMediaVideoGamelist>
            <showLastPlayed>true</showLastPlayed>
            <showMediaScreenshot>true</showMediaScreenshot>
            <mediaVideoPos>999 999</mediaVideoPos>
            <showBackgroundVideo>false</showBackgroundVideo>
            <showBackgroundArt>true</showBackgroundArt>
        </variables>
    </colorScheme>
    
    <colorScheme name="nomedia">
        <variables>
            <showMediaVideoSystem>false</showMediaVideoSystem>
            <showMediaVideoGamelist>false</showMediaVideoGamelist>
            <showLastPlayed>false</showLastPlayed>
            <showMediaScreenshot>false</showMediaScreenshot>
            <mediaVideoPos>0.830 0.725</mediaVideoPos>
            <showBackgroundVideo>false</showBackgroundVideo>
            <showBackgroundArt>true</showBackgroundArt>
        </variables>
    </colorScheme>
    
    <colorScheme name="backgroundvideo">
        <variables>
            <showMediaVideoSystem>true</showMediaVideoSystem>
            <showMediaVideoGamelist>false</showMediaVideoGamelist>
            <showLastPlayed>true</showLastPlayed>
            <showMediaScreenshot>false</showMediaScreenshot>
            <mediaVideoPos>0.830 0.725</mediaVideoPos>
            <showBackgroundVideo>true</showBackgroundVideo>
            <showBackgroundArt>false</showBackgroundArt>
        </variables>
    </colorScheme>
    
    <colorScheme name="backgroundvideo-screenshot">
        <variables>
            <showMediaVideoSystem>false</showMediaVideoSystem>
            <showMediaVideoGamelist>false</showMediaVideoGamelist>
            <showLastPlayed>true</showLastPlayed>
            <showMediaScreenshot>true</showMediaScreenshot>
            <mediaVideoPos>0.830 0.725</mediaVideoPos>
            <showBackgroundVideo>true</showBackgroundVideo>
            <showBackgroundArt>false</showBackgroundArt>
        </variables>
    </colorScheme>
</theme>
