<themeCapabilities>
	
    <themeName>PS5 Menu</themeName>
    
    <aspectRatio>16:9</aspectRatio>
	<aspectRatio>20:9</aspectRatio>
    
    <fontSize>small</fontSize>
    
    <variant name="carousel-small">
      <label>Carousel - Small</label>
      <selectable>true</selectable>
   </variant>
   <variant name="carousel-large">
      <label>Carousel - Large</label>
      <selectable>true</selectable>
   </variant>
    
    <colorScheme name="mediavideo">
        <label>Media Video</label>
    </colorScheme>
    <colorScheme name="mediascreenshot">
        <label>Media Screenshot</label>
    </colorScheme>
    <colorScheme name="mediavideo-audio">
        <label>Media Video (Audio Only)</label>
    </colorScheme>
    <colorScheme name="nomedia">
        <label>No Media</label>
    </colorScheme>
    <colorScheme name="backgroundvideo">
        <label>Background Video</label>
    </colorScheme>
    <colorScheme name="backgroundvideo-screenshot">
        <label>Background Video (with Screenshot)</label>
    </colorScheme>

</themeCapabilities>
