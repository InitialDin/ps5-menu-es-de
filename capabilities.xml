<themeCapabilities>
	
    <themeName>PS5 Menu</themeName>
    
    <aspectRatio>16:9</aspectRatio>
    <aspectRatio>16:10</aspectRatio>
    <aspectRatio>4:3</aspectRatio>
    <aspectRatio>3:2</aspectRatio>
	<aspectRatio>20:9</aspectRatio>
    
    <variant name="carousel-small">
      <label>Carousel (Small)</label>
      <selectable>true</selectable>
   </variant>
   <variant name="carousel-large">
      <label>Carousel (Large)</label>
      <selectable>true</selectable>
   </variant>
   <variant name="carousel-xmb-cover-small">
      <label>Carousel (Small) + XMB (Cover)</label>
      <selectable>true</selectable>
   </variant>
   <variant name="carousel-xmb-min-small">
      <label>Carousel (Small) + XMB (Minimal)</label>
      <selectable>true</selectable>
   </variant>
   <variant name="carousel-xmb-marquee-small">
      <label>Carousel (Small) + XMB (Marquee)</label>
      <selectable>true</selectable>
   </variant>
   <variant name="carousel-xmb-title-small">
      <label>Carousel (Small) + XMB (Title Screen)</label>
      <selectable>true</selectable>
   </variant>
   <variant name="carousel-xmb-physicalmedia-small">
      <label>Carousel (Small) + XMB (Physical Media)</label>
      <selectable>true</selectable>
   </variant>
   <variant name="carousel-xmb-cover-large">
      <label>Carousel (Large) + XMB (Cover)</label>
      <selectable>true</selectable>
   </variant>
   <variant name="carousel-xmb-min-large">
      <label>Carousel (Large) + XMB (Minimal)</label>
      <selectable>true</selectable>
   </variant>
   <variant name="carousel-xmb-marquee-large">
      <label>Carousel (Large) + XMB (Marquee)</label>
      <selectable>true</selectable>
   </variant>
   <variant name="carousel-xmb-title-large">
      <label>Carousel (Large) + XMB (Title Screen)</label>
      <selectable>true</selectable>
   </variant>
   <variant name="carousel-xmb-physicalmedia-large">
      <label>Carousel (Large) + XMB (Physical Media)</label>
      <selectable>true</selectable>
   </variant>
    
    <colorScheme name="mediavideo">
        <label>Media - Video</label>
    </colorScheme>
    <colorScheme name="mediascreenshot">
        <label>Media - Screenshot</label>
    </colorScheme>
    <colorScheme name="mediamiximage">
        <label>Media - Mix Image</label>
    </colorScheme>
    <colorScheme name="mediavideo-audio">
        <label>Media - Video (Audio Only)</label>
    </colorScheme>
    <colorScheme name="mediavideo-audio-screenshot">
        <label>Media - Video (Audio Only + Screenshot)</label>
    </colorScheme>
    <colorScheme name="mediavideo-audio-miximage">
        <label>Media - Video (Audio Only + Mix Image)</label>
    </colorScheme>
    <colorScheme name="backgroundvideo">
        <label>Background Video</label>
    </colorScheme>
    <colorScheme name="backgroundvideo-screenshot">
        <label>Background Video (Screenshot)</label>
    </colorScheme>
    <colorScheme name="backgroundvideo-miximage">
        <label>Background Video (Mix Image)</label>
    </colorScheme>
    <colorScheme name="nomedia">
        <label>No Media</label>
    </colorScheme>

    <transitions name="transitions">
		<label>transitions</label>
		<selectable>false</selectable>
		<systemToSystem>instant</systemToSystem>
		<systemToGamelist>instant</systemToGamelist>
		<gamelistToGamelist>instant</gamelistToGamelist>
		<gamelistToSystem>instant</gamelistToSystem>
		<startupToSystem>fade</startupToSystem>
		<startupToGamelist>fade</startupToGamelist>
	</transitions>
	<suppressTransitionProfiles>
		<entry>builtin-instant</entry>
		<entry>builtin-slide</entry>
		<entry>builtin-fade</entry>
	</suppressTransitionProfiles>
    
</themeCapabilities>
